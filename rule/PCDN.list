# PCDN Filter List
# 整理、合并自多个来源
# 更新时间: 2026-03-11
# 来源: https://github.com/smdx/AdGHome_Filter_List/blob/main/AdGHome-PCDN.txt
# - https://github.com/Womsxd/MyAdBlockRules
# - https://github.com/4fuu/AdGuard-Home-PCDN
# - https://github.com/743859910/OpenHosts
# - https://github.com/susetao/PCDNFilter-CHN-
# - https://github.com/thhbdd/Block-pcdn-domains
#
# 注意：手动添加的规则请放在文件的"自定义规则"部分
#

# 腾讯
DOMAIN-SUFFIX,stun.qqlive.qq.com
DOMAIN-SUFFIX,musicstun.p2p.qq.com
DOMAIN-SUFFIX,p2p.qq.com
DOMAIN-SUFFIX,p2ptun.qq.com
DOMAIN-SUFFIX,p2pupdate.gamedl.qq.com
DOMAIN-SUFFIX,p2pupgrade.gamedl.qq.com
# 上面两个的cname解析结果
DOMAIN-SUFFIX,stun-a1.qq.com
# 疑似腾讯云stun服务器
DOMAIN-SUFFIX,signal.qvb.qcloud.com
# stun*.qvb.qcloud.com

# 快手
# /^(.+)-p2p-pull\.(video|live)-voip\.com$/
# /^(.+)-p2p\.pull\.yximgs\.com$/
# /^(.+)-p2p-(.+)\.pull\.yximgs\.com$/
DOMAIN-SUFFIX,pcdn.yximgs.com
# ||config-p2p-*.vcloud.ks-live.com^
DOMAIN-SUFFIX,slb-p2p.vcloud.ks-live.com
# 疑似p2p cdn文件
DOMAIN-SUFFIX,yximgs-webrtc.liveplay.myqcloud.com
# xxpkg系 疑似快手关联公司
# ||*pcdn*.xxpkg.com^
DOMAIN-SUFFIX,p2p-punch.xxpkg.com
# ||p2p-punch-*.xxpkg.com^

